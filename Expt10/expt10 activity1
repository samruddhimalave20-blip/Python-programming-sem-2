import streamlit as st

st.title("🛒 Grocery Bill Calculator")

st.write("Enter item details:")

# Initialize session state to store items
if "items" not in st.session_state:
    st.session_state.items = []

# Input fields
item_name = st.text_input("Item Name")
price = st.number_input("Price (₹)", min_value=0.0, step=1.0)
quantity = st.number_input("Quantity", min_value=1, step=1)

# Add item button
if st.button("Add Item"):
    if item_name:
        total = price * quantity
        st.session_state.items.append((item_name, price, quantity, total))
        st.success(f"{item_name} added!")
    else:
        st.error("Please enter item name")

# Display items
st.subheader("🧾 Bill Details")
grand_total = 0

if st.session_state.items:
    for item in st.session_state.items:
        st.write(f"{item[0]} - ₹{item[1]} x {item[2]} = ₹{item[3]}")
        grand_total += item[3]

    st.markdown(f"### 💰 Total Bill: ₹{grand_total}")
else:
    st.write("No items added yet.")

# Clear button
if st.button("Clear Bill"):
    st.session_state.items = []
    st.warning("Bill cleared!")
